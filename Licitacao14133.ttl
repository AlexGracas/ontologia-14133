[ rdf:type owl:AllDisjointClasses ] owl:members (:GovernoFederal :GovernoMunicipal :GovernoEstadual).
:Governo owl:equivalentClass [
  rdf:type owl:Class;
  owl:unionOf (:GovernoFederal :GovernoMunicipal :GovernoEstadual)
].
:Autor owl:equivalentClass [
  rdf:type owl:Class;
  owl:unionOf (:AutorCorporativo :AutorPessoaFisica)
].
