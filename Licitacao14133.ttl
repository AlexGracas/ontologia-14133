    rdfs:label "dependente"@en.
:ModalidadeLicitacao rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:inheresIn ];
  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :ProcessoLicitatrio
].
:ProcessoLicitatrio rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty gufo:inheresIn;
  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :ModalidadeLicitacao
].
:EditalLicitacao rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:inheresIn ];
  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :IndiceReajustamentoDePreco
].
:IndiceReajustamentoDePreco rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty gufo:inheresIn;
  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :EditalLicitacao
].
:Contratado rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:mediates ];
  owl:someValuesFrom :Contrato
].
:Contrato rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty gufo:mediates;
  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :Contratado
], [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:mediates ];
  owl:someValuesFrom :Contratante
].
:Contratante rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty gufo:mediates;
  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :Contrato
].
:AgenteDeContratacao rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:isCollectionMemberOf ];
  owl:someValuesFrom :EquipeApoio
].
:EquipeApoio rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty gufo:isCollectionMemberOf;
  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :AgenteDeContratacao
].
:Casamento rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:mediates ];
  owl:qualifiedCardinality "2"^^xsd:nonNegativeInteger;
  owl:onClass :Conjugue
].
:Conjugue rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty gufo:mediates;
  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :Casamento
].
:ModalidadeContratacaoDireta rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:inheresIn ];
  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :ProcessoDeContratacaoDireta
].
:ProcessoDeContratacaoDireta rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty gufo:inheresIn;
  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :ModalidadeContratacaoDireta
].
:ModalidadeContratacaoDireta rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:inheresIn ];
  owl:qualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :MotivoContratacaoDireta
].
:MotivoContratacaoDireta rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty gufo:inheresIn;
  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :ModalidadeContratacaoDireta
].
:RecursoDeMidiaVirtual rdfs:subClassOf [
  rdf:type owl:Restriction;
  owl:onProperty [ owl:inverseOf gufo:manifestedIn ];
  owl:minQualifiedCardinality "1"^^xsd:nonNegativeInteger;
  owl:onClass :Documento
].
