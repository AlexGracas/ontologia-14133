    rdfs:range :ProcessoLicitatrio;
    rdfs:label "similares"@en;
    rdfs:comment "Processos similares servem para fundamentar a construção do Estudo Técnico Preliminar."@en.
:matrizDeRiscosHasEstudoTecnicoPreliminar rdf:type owl:ObjectProperty;
